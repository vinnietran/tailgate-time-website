{
  "name": "tailgatetime-host-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lot-legends": "vite build --mode lot-legends",
    "build:prod": "vite build --mode tailgatetime-prod",
    "preview": "vite preview",
    "deploy:hosting:lot-legends": "npm run build:lot-legends && firebase deploy --project lot-legends --only hosting",
    "deploy:hosting:prod": "npm run build:prod && firebase deploy --project tailgatetime-prod --only hosting",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"tests/**/*.ts\" \"vite.config.ts\" \"playwright.config.ts\"",
    "typecheck": "tsc --noEmit",
    "verify": "npm run typecheck && npm run build",
    "ci": "npm run lint && npm run verify && npm run test:e2e:mock",
    "test:e2e": "playwright test",
    "test:e2e:mock": "playwright test",
    "test:e2e:qa": "PLAYWRIGHT_E2E_MODE=qa playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "firebase": "^10.12.2",
    "heic-to": "^1.4.2",
    "heic2any": "0.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^10.0.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.57.1",
    "vite": "^5.2.0"
  }
}
